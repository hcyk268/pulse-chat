SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

POSTGRES_DB=chat_app
POSTGRES_PORT=5433

DB_URL=jdbc:postgresql://localhost:5433/chat_app
DB_USERNAME=chat_user
DB_PASSWORD=change_me_db_password

JWT_ACCESS_TOKEN_SECRET=change-me-access-token-secret-at-least-32-characters
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION_MS=86400000
JWT_REFRESH_TOKEN_EXPIRATION_MS=864000000

CORS_ALLOWED_ORIGINS=http://localhost:5173
JPA_DDL_AUTO=update
HIBERNATE_FORMAT_SQL=true

R2_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public R2 custom domain or r2.dev domain, for example: https://media.example.com
R2_PUBLIC_BASE_URL=
R2_PRESIGNED_UPLOAD_TTL=10m
R2_MAX_FILE_SIZE_BYTES=26214400
R2_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4,video/webm,audio/mpeg,audio/ogg,application/pdf,text/plain,application/zip
