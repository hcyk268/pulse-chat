SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

POSTGRES_DB=chat_app
POSTGRES_PORT=5433

DB_URL=jdbc:postgresql://localhost:5433/chat_app
DB_USERNAME=chat_user
DB_PASSWORD=change_me_db_password

JWT_ACCESS_TOKEN_SECRET=change-me-access-token-secret-at-least-32-characters
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-at-least-32-characters
JWT_ACCESS_TOKEN_EXPIRATION_MS=86400000
JWT_REFRESH_TOKEN_EXPIRATION_MS=864000000

CORS_ALLOWED_ORIGINS=http://localhost:5173
JPA_DDL_AUTO=update
HIBERNATE_FORMAT_SQL=true
